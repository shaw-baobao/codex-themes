{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-themes.dev/schemas/theme.schema.json",
  "title": "Codex theme",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "slug",
    "author",
    "type",
    "mode",
    "tags",
    "codeThemeId",
    "theme"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "app"
    },
    "mode": {
      "type": "string",
      "enum": ["light", "dark"]
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "description": {
      "type": "string"
    },
    "codeThemeId": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accent",
        "background",
        "foreground",
        "contrast",
        "fonts"
      ],
      "properties": {
        "accent": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "foreground": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "surface": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "contrast": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "fonts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ui", "code"],
          "properties": {
            "ui": {
              "type": "string",
              "minLength": 1
            },
            "code": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
